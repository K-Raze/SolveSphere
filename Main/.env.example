PORT=3000

# MongoDB Configuration
# Get this from MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
DB_CONNECT_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database_name>?retryWrites=true&w=majority

# JWT Secret
# Generate a random string (e.g., using `openssl rand -hex 32` or similar)
JWT_KEY=your_super_secret_jwt_key_here

# Redis Configuration
# Get these details from Redis Cloud (https://redis.com/try-free/) or your local Redis instance
REDIS_HOST=your_redis_host
REDIS_PORT=your_redis_port
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
